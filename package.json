{
  "name": "c404-blog-monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo dev",
    "dev:frontend": "turbo dev --filter=frontend",
    "dev:backend": "turbo dev --filter=backend",
    "dev:ai": "turbo dev --filter=ai-service",
    "dev:mobile": "turbo start --filter=mobile",
    "dev:mobile:ios": "turbo ios --filter=mobile",
    "dev:mobile:android": "turbo android --filter=mobile",
    "build": "turbo build",
    "build:frontend": "turbo build --filter=frontend",
    "lint": "turbo lint",
    "lint:frontend": "turbo lint --filter=frontend",
    "test": "turbo test",
    "codegen": "turbo codegen",
    "generate": "turbo generate",
    "tauri": "cd apps/desktop && ../../node_modules/.bin/tauri",
    "tauri:dev": "cd apps/desktop && ../../node_modules/.bin/tauri dev",
    "tauri:build": "cd apps/desktop && ../../node_modules/.bin/tauri build"
  },
  "devDependencies": {
    "turbo": "^2.9.3"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "@react-native/babel-plugin-codegen": "0.85.1"
    }
  }
}
