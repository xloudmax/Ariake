# =============================================================================
# apps/backend · .env (Go server)
# =============================================================================
# Copy to `apps/backend/.env`. Never commit. Refer to apps/backend/CONFIG.md
# for the full reference.
# -----------------------------------------------------------------------------

# ---------- Runtime ----------
# development | production | test
GIN_MODE=development
PORT=11451
LOG_LEVEL=info

# ---------- Main DB ----------
# Dev: SQLite file path (default `blog_platform.db`).
# Prod: PostgreSQL DSN. Use sslmode=verify-full + a real CA whenever possible.
DATABASE_URL=blog_platform.db
# Force the driver explicitly when the DSN above is ambiguous.
DB_TYPE=sqlite
# Example PG DSN:
# DATABASE_URL=postgres://blog:CHANGE_ME@127.0.0.1:5432/blog?sslmode=verify-full

# ---------- GraphRAG / pgvector DB ----------
# Required for AI / knowledge-graph features. Leave empty to disable.
# DSN format: GORM postgres (libpq style or URL).
POSTGRES_DSN=

# ---------- JWT ----------
# REQUIRED in production. Must be >=32 random bytes (base64 / hex). The server
# refuses to start with empty / `JNU_technicians_club` / placeholder values.
# Generate one: `openssl rand -base64 48`
JWT_SECRET=
BCRYPT_COST=12
SESSION_TIMEOUT=24h
REFRESH_TOKEN_TIMEOUT=168h

# ---------- First-run admin (optional) ----------
# When BOTH are set on first boot AND no admin row exists, the server creates
# the account. INITIAL_ADMIN_PASSWORD must be >=12 chars. Unset both after
# the first successful boot — they are NOT used to rotate an existing admin.
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_EMAIL=

# ---------- CORS ----------
# Comma-separated list. Wildcard `*` allowed only outside production.
ALLOWED_ORIGINS=http://localhost:5173

# ---------- Rate limit ----------
RATE_LIMIT_ENABLED=true
REQUESTS_PER_MINUTE=100
REQUESTS_PER_HOUR=1000

# ---------- Cache ----------
CACHE_ENABLED=true
CACHE_TTL=900s
# Leave REDIS_HOST empty to fall back to in-memory go-cache.
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- AI sidecar ----------
AI_SERVICE_URL=http://127.0.0.1:8000
AI_SERVICE_TIMEOUT=150s

# ---------- Email (optional) ----------
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ---------- File uploads ----------
BASE_PATH=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.md,.txt,.json,.jpg,.jpeg,.png,.gif,.webp

# ---------- GitHub OAuth (optional) ----------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:11451/api/auth/github/callback

# ---------- Notion sync (optional) ----------
NOTION_API_KEY=

# ---------- Debug ----------
# Set to true to expose pprof on :6060 (NEVER on the public internet).
ENABLE_PPROF=false
