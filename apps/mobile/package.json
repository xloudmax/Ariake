{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "codegen": "graphql-codegen --config codegen.yml",
    "lint": "eslint \"{app,src}/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"{app,src}/**/*.{ts,tsx}\" --fix",
    "type-check": "tsc --noEmit",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test \"src/**/*.test.ts\"",
    "test:watch": "node --watch --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test \"src/**/*.test.ts\"",
    "test:tdd": "pnpm test:watch"
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@c404/shared": "workspace:*",
    "@expo/ui": "0.2.0-beta.9",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@shopify/flash-list": "2.0.2",
    "@types/katex": "^0.16.8",
    "@types/markdown-it": "^14.1.2",
    "apollo3-cache-persist": "^0.15.0",
    "expo": "~54.0.34",
    "expo-asset": "~12.0.13",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.22",
    "expo-glass-effect": "~0.1.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "graphql": "^16.11.0",
    "i18n-js": "^4.5.3",
    "katex": "^0.16.45",
    "markdown-it": "^14.1.1",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-operations": "^4.6.1",
    "@graphql-codegen/typescript-react-apollo": "^4.3.3",
    "@types/react": "~19.1.10",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "neostandard": "^0.13.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true
}
