# =============================================================================
# apps/ai-service · .env (FastAPI sidecar)
# =============================================================================
# Copy to `apps/ai-service/.env`. Never commit. Companion docs:
# apps/ai-service/CLAUDE.md  +  apps/ai-service/API_REFERENCE.md
# -----------------------------------------------------------------------------

# ---------- LLM / embeddings ----------
# Vertex AI Express Mode key (preferred). LLM_API_KEY is an alias.
GOOGLE_CLOUD_API_KEY=
LLM_API_KEY=
# Fallback when no API key — uses Application Default Credentials.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
# Model choices (see model_config.yaml for the per-task routing).
LLM_MODEL=publishers/google/models/gemini-3.1-flash-lite-preview
EMBEDDING_MODEL=text-embedding-004

# ---------- Knowledge-graph PostgreSQL (pgvector) ----------
# REQUIRED for /graph/*, /knowledge/*, /search/* endpoints. Leave empty to run
# the service in degraded mode (mechanism trees still work; search returns
# DB_MISSING_ANSWER).
GRAPH_DATABASE_URL=

# ---------- API key middleware (optional) ----------
# When set, every non-public route requires `X-API-Key: <value>`.
AI_SERVICE_API_KEY=

# ---------- Logging ----------
LOG_LEVEL=INFO

# ---------- Self-reference for orchestration scripts ----------
AI_SERVICE_URL=http://127.0.0.1:8000
