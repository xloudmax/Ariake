{
  "name": "ai-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "echo 'No build step for python'",
    "test": "uv run pytest",
    "test:cov": "uv run pytest --cov-report=html --cov-report=xml",
    "test:watch": "uv run pytest-watch",
    "dev": "uv run python -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "docker:build": "docker build -t c404-ai-service:latest .",
    "docker:build:dev": "docker build -f Dockerfile.dev -t c404-ai-service:dev .",
    "docker:run": "docker run -d --name ai-service -p 8000:8000 --env-file .env c404-ai-service:latest",
    "docker:run:dev": "docker run -d --name ai-service-dev -p 8000:8000 --env-file .env -v $(pwd):/app c404-ai-service:dev",
    "docker:stop": "docker stop ai-service || true",
    "docker:logs": "docker logs -f ai-service",
    "discover-openalex": "uv run python -m scripts.discover_openalex",
    "expand-openalex": "uv run python -m scripts.expand_openalex_neighbors",
    "review-openalex": "uv run python -m scripts.review_openalex_corpus",
    "preview-openalex-selection": "uv run python -m scripts.preview_materialization_selection",
    "build-seed-knowledge": "uv run python -m scripts.build_seed_knowledge",
    "build-seed-knowledge:full": "uv run python -m scripts.build_seed_knowledge --full-corpus --include-fulltext-excerpt",
    "load-seed-knowledge": "uv run python -m scripts.load_seed_knowledge",
    "analyze-benchmark-coverage": "uv run python -m scripts.analyze_benchmark_coverage",
    "corpus-v2:discover": "uv run python -m scripts.discover_openalex --version corpus_v2",
    "corpus-v2:expand": "uv run python -m scripts.expand_openalex_neighbors --version corpus_v2",
    "corpus-v2:review": "uv run python -m scripts.review_openalex_corpus --version corpus_v2",
    "corpus-v2:preview": "uv run python -m scripts.preview_materialization_selection --version corpus_v2 --per-pack-limit 12",
    "corpus-v2:build": "uv run python -m scripts.build_seed_knowledge --version corpus_v2 --per-pack-limit 12",
    "corpus-v2:load": "uv run python -m scripts.load_seed_knowledge --version corpus_v2",
    "corpus-v2:analyze": "uv run python -m scripts.analyze_benchmark_coverage --version corpus_v2",
    "corpus-v3:discover": "uv run python -m scripts.discover_openalex --version corpus_v3",
    "corpus-v3:expand": "uv run python -m scripts.expand_openalex_neighbors --version corpus_v3",
    "corpus-v3:review": "uv run python -m scripts.review_openalex_corpus --version corpus_v3",
    "corpus-v3:preview": "uv run python -m scripts.preview_materialization_selection --version corpus_v3 --per-pack-limit 16",
    "corpus-v3:build": "uv run python -m scripts.build_seed_knowledge --version corpus_v3 --per-pack-limit 16",
    "corpus-v3:load": "uv run python -m scripts.load_seed_knowledge --version corpus_v3",
    "corpus-v3:analyze": "uv run python -m scripts.analyze_benchmark_coverage --version corpus_v3",
    "benchmark": "python -c \"raise SystemExit('Deprecated entry: use pnpm benchmark:paper-core:v2:drr, pnpm benchmark:paper-core:v2:zero-shot, or pnpm benchmark:advanced')\"",
    "benchmark:paper-core:v2:drr": "BENCHMARK_QUERY_SET=paper_core BENCHMARK_QUERY_LIMIT=6 BENCHMARK_VERSION=paper_core_v2 BENCHMARK_CORPUS_VERSION=corpus_v3_scale BENCHMARK_PIPELINE_VARIANT=DRR_Final BENCHMARK_JUDGE_PROFILE=paper_core_v2_neutral uv run python -m scripts.run_benchmark",
    "benchmark:paper-core:v2:zero-shot": "PAPER_CORE_ZERO_SHOT_VERSION=paper_core_v2 PAPER_CORE_ZERO_SHOT_CORPUS_VERSION=corpus_v3_scale PAPER_CORE_ZERO_SHOT_PIPELINE_VARIANT=Zero_Shot PAPER_CORE_ZERO_SHOT_JUDGE_PROFILE=paper_core_v2_neutral PAPER_CORE_ZERO_SHOT_QUERY_LIMIT=6 uv run python -m scripts.run_paper_core_zero_shot",
    "benchmark:full70": "echo 'Deprecated: benchmark:full70 is no longer supported' && exit 1",
    "benchmark:advanced": "ADVANCED_ABLATION_QUERY_SET=v2 uv run python -m scripts.run_advanced_ablation",
    "benchmark:advanced:legacy": "ADVANCED_ABLATION_QUERY_SET=legacy uv run python -m scripts.run_advanced_ablation",
    "benchmark:blind-test:generate": "uv run python -m scripts.generate_blind_ab_answers",
    "benchmark:blind-test:eval": "uv run python -m scripts.run_blind_ab_testing",
    "retest:cold-start": "uv run python -m scripts.run_cold_start_retest",
    "figures:current": "uv run python doc/latex/generate_current_figures.py",
    "db:check": "uv run python -m scripts.test_db_conn",
    "db:smoke": "uv run python -m scripts.run_postgres_smoke"
  }
}
