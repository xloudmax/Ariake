{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "codegen", "generate"],
      "outputs": ["dist/**", ".next/**", "bin/**"]
    },
    "ai-service#build": {
      "outputs": []
    },
    "codegen": {
      "inputs": ["../../apps/backend/graph/schema.graphql", "codegen.yml", "src/api/graphql/**", "src/graphql/**/*.graphql"],
      "outputs": ["src/generated/**"]
    },
    "generate": {
      "inputs": ["graph/*.graphql", "gqlgen.yml"],
      "outputs": ["graph/generated.go", "graph/model/models_gen.go"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "tests/**/*.ts", "tests/**/*.go"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "ios": {
      "cache": false,
      "persistent": true
    },
    "android": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
