# =============================================================================
# deploy/.env.deploy.example — read by deploy/deploy.sh
# =============================================================================
# Copy to `deploy/.env.deploy` on the deploy host. Never commit the result.
# These vars drive the build/copy step; they do NOT replace the per-app .env
# files at /var/www/blog/apps/<svc>/.env.
# -----------------------------------------------------------------------------

# Public URL the frontend bundle will hit. Baked into JS at build time.
PUBLIC_API_BASE_URL=https://blog.example.com

# Where to install the bundle. The deploy script will create these dirs.
DEPLOY_USER=www-data
APP_DIR=/var/www/blog
BACKEND_DIR=/var/www/blog/apps/backend
FRONTEND_DIR=/var/www/blog/dist
AI_SERVICE_DIR=/var/www/blog/apps/ai-service

# Whether to re-build the AI service Python venv on each deploy (set to "false"
# if the venv is managed via a separate process / OS package).
REBUILD_AI_VENV=true

# How many old DB backups to keep when running deploy/scripts/backup_db.sh.
BACKUP_RETAIN=14
