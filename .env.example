# =============================================================================
# C404-blog · root .env (compose-level convenience)
# =============================================================================
# This file is read by `docker compose` and a handful of dev scripts at the
# repo root. **Real per-service config lives in apps/<svc>/.env** — see those
# .env.example files for full var lists.
#
# Copy to `.env` and fill in. Never commit the resulting file.
# -----------------------------------------------------------------------------

# ---------- Compose: PostgreSQL service ----------
# Used by docker-compose.yml to seed the dev pgvector container.
POSTGRES_VERSION=pg16
POSTGRES_USER=blog
POSTGRES_PASSWORD=CHANGE_ME_strong_random
POSTGRES_DB=blog
POSTGRES_GRAPH_DB=blog_graph
# If 1, publishes 5432 on the host. Leave 0 for normal dev.
EXPOSE_PG=0

# ---------- Compose: image build args ----------
# Baked into the frontend bundle at build time. Point to your nginx host in prod.
FRONTEND_API_BASE_URL=http://localhost:11451

# ---------- Compose: networking ----------
# Where backend/ai-service bind on the host. 127.0.0.1 only by default.
BACKEND_BIND=127.0.0.1:11451
AI_SERVICE_BIND=127.0.0.1:8000
FRONTEND_BIND=127.0.0.1:5173
